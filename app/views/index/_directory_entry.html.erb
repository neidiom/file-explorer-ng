<tr>
  <td class="name">
    <%= link_to entry.relative_url, class: entry.type.to_s do %>
      <%= fa_icon entry.icon_class %>
      <span class="filename"><%= entry.display_name %></span>
    <% end %>
  </td>
  <td>
    <%= entry.human_size %>
  </td>
  <td class="date">
    <%= entry.formatted_date %>
  </td>
  <td>
    <% unless entry.ignored? %>
      <%= link_to '#',
          class: 'delete',
          onclick: "window.fileExplorer.rename('#{entry.relative_url}')" do %>
        <%= fa_icon 'i-cursor' %> Rename
      <% end %>
    <% end %>
  </td>
  <td>
    <% unless entry.ignored? %>
      <%= link_to entry.relative_url,
          method: :delete,
          class: 'delete',
          data: {
            turbo_method: :delete,
            turbo_confirm: "Are you sure you want to delete '#{entry.path}'?"
          } do %>
        <%= fa_icon 'trash' %> Delete
      <% end %>
    <% end %>
  </td>
</tr>
